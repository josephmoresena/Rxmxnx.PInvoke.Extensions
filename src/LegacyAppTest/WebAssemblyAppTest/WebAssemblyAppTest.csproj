<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>netstandard2.1</TargetFramework>
        <RazorLangVersion>3.0</RazorLangVersion>
    </PropertyGroup>

    <Import Project="..\LegacyProject.props"/>
    <ItemGroup>
        <ProjectReference Include="..\LegacyAppTest.Core\LegacyAppTest.Core.csproj">
        </ProjectReference>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="3.2.1"/>
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Build" Version="3.2.1" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="5.0.17" PrivateAssets="all"/>
        <PackageReference Include="System.Net.Http.Json" Version="3.2.1"/>
    </ItemGroup>

    <Target Name="RemoveUnsafeFromWasmRuntime" AfterTargets="_ResolveBlazorInputs">
        <ItemGroup>
            <!-- WebAssembly BCL ships an older System.Runtime.CompilerServices.Unsafe, causing ILLink missing-method errors, so it is removed. -->
            <_WebAssemblyBCLAssembly Remove="$(ComponentsWebAssemblyBaseClassLibraryPath)System.Runtime.CompilerServices.Unsafe.dll"/>
        </ItemGroup>
    </Target>

</Project>
